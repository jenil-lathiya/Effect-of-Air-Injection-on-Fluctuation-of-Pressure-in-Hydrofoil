FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0.41;

boundaryField
{
    bottomWall
    {
        type            kqRWallFunction;
        value           $internalField;
    }
    CLARK_Y_AIRFOIL
    {
        type            kqRWallFunction;
        value           $internalField;
    }
    inlet
    {
        type            fixedValue;
        value           $internalField;
    }
    outlet
    {
        type            zeroGradient;
    }
    side1
    {
        type            symmetry;
    }
    side2
    {
        type            symmetry;
    }
    tap1
    {
        type            zeroGradient;
    }
    tap5
    {
        type            kqRWallFunction;
        value           $internalField;
    }
    upperWall
    {
        type            kqRWallFunction;
        value           $internalField;
    }
}


